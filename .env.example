# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_DOMAIN=https://your-public-domain.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Site Configuration
SITE_DOMAIN=http://localhost:8788
ADMIN_EMAIL=admin@example.com

# Storage Configuration (in bytes)
DEFAULT_STORAGE_QUOTA=5368709120
MAX_FILE_SIZE=104857600

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_EXPIRE_HOURS=24

# API Configuration
VITE_API_BASE_URL=/api
VITE_APP_TITLE=CloudFlare Image Host
VITE_R2_DOMAIN=https://your-r2-domain.com
VITE_CLOUDFLARE_ACCOUNT_ID=your_account_id
